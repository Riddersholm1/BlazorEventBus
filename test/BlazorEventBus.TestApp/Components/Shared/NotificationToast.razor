@using BlazorEventBus.EventBus

@implements IDisposable
@inject IEventBus EventBus

@if (_visible)
{
    <div class="alert alert-@_level alert-dismissible fade show position-fixed bottom-0 end-0 m-3" style="z-index:9999; min-width:300px;">
        @_text
        <button type="button" class="btn-close" @onclick="Dismiss"></button>
    </div>
}

@code {
    private bool _visible;
    private string _text = string.Empty;
    private string _level = "info";
    private IDisposable? _subscription;

    protected override void OnInitialized()
    {
        _subscription = EventBus.Subscribe<NotificationPosted>(e =>
        {
            _text = e.Message;
            _level = e.Level;
            _visible = true;
            InvokeAsync(StateHasChanged);
        });
    }

    private void Dismiss() => _visible = false;

    public void Dispose() => _subscription?.Dispose();
}